{
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.formatOnSave": true
  },
  "[vue]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.formatOnSave": true
  },
  "[yaml]": {
    "editor.defaultFormatter": "kennylong.kubernetes-yaml-formatter",
    "editor.formatOnSave": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.organizeImports": "never"
  },
  "eslint.format.enable": true,
  "yaml.format.singleQuote": false,
  "yaml.format.bracketSpacing": false,

  "workbench.colorCustomizations": {
    "editorWarning.background": "#ff0000",
    "activityBar.activeBackground": "#e4d4d3",
    "activityBar.background": "#e4d4d3",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#619e65",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#e4d4d3",
    "statusBar.background": "#d1b5b3",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#be9693",
    "statusBarItem.remoteBackground": "#d1b5b3",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#d1b5b3",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#d1b5b399",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "#d1b5b3"
}
