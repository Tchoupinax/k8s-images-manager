{
  "name": "server",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "node --no-warnings --experimental-strip-types src/index.mts",
    "watch": "node --no-warnings --experimental-strip-types --watch src/index.mts",
    "build": "npx prisma generate && tsc",
    "lint": "eslint . --fix",
    "migrate": "DATABASE_URL=postgresql://postgres:mysecret@localhost:5439/postgres npx prisma migrate dev",
    "test": "vitest run --config vitest.e2e.config.mts"
  },
  "dependencies": {
    "@electric-sql/pglite": "0.2.17",
    "@fastify/cors": "11.2.0",
    "@fastify/request-context": "6.2.1",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@prisma/client-runtime-utils": "7.4.2",
    "fastify": "5.8.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prisma": "7.4.2",
    "prom-client": "15.1.3",
    "valienv": "1.1.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@types/node": "25.3.3",
    "eslint": "10.0.2",
    "eslint-config-tchoupinax": "^2.4.0",
    "nodemon": "3.1.14",
    "pglite-prisma-adapter": "0.7.2",
    "typescript": "5.9.3",
    "vite-node": "5.3.0",
    "vitest": "3.2.4"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
