{
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check": "gitleaks dir -v && gitleaks git -v",
    "knip": "knip",
    "lint": "turbo run lint",
    "lint:dockerfile": "turbo run lint:dockerfile",
    "prewatch": "docker compose up -d",
    "test": "turbo run test",
    "upgrade": "pnpm ncu -p pnpm -i --cooldown 3 --format group",
    "watch": "turbo run watch"
  },
  "devDependencies": {
    "knip": "6.11.0",
    "npm-check-updates": "21.0.3",
    "turbo": "2.9.7"
  },
  "packageManager": "pnpm@10.33.2"
}
