{
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check": "gitleaks dir -v && gitleaks git -v",
    "knip": "knip",
    "lint": "turbo run lint",
    "lint:dockerfile": "turbo run lint:dockerfile",
    "prewatch": "docker compose up -d",
    "test": "turbo run test",
    "upgrade": "pnpm ncu -p pnpm -w -i --cooldown 3 --format group",
    "watch": "turbo run watch",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "knip": "6.14.1",
    "npm-check-updates": "22.2.0",
    "turbo": "2.9.14"
  },
  "packageManager": "pnpm@11.2.1"
}
